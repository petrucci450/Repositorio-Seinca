<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Heredamos la vista tree de sale.order.line para mostrar los lotes -->
    <record id="view_order_line_tree_inherit_lote" model="ir.ui.view">
        <field name="name">sale.order.line.tree.inherit.lote</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="sale.view_order_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="lot_ids" widget="many2many_tags" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>

    <!-- Heredamos la vista form de sale.order.line para mostrar los lotes -->
    <record id="view_order_line_form_inherit_lote" model="ir.ui.view">
        <field name="name">sale.order.line.form.inherit.lote</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="sale.view_order_line_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="lot_ids" widget="many2many_tags" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
